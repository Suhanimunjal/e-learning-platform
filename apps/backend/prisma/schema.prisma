generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String
  password        String?
  role            Role     @default(STUDENT)
  avatar          String?
  organizationId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  organization    Organization? @relation(fields: [organizationId], references: [id])
  coursesCreated  Course[]      @relation("InstructorCourses")
  enrollments     Enrollment[]
  orders          Order[]
  submissions     Submission[]
  quizAttempts    QuizAttempt[]
  discussions     Discussion[]
  replies         Reply[]
  notifications   Notification[]
  subscriptions   Subscription[]
  progresses      Progress[]
  certificates    Certificate[]
  analyticsEvents AnalyticsEvent[]
  reviews         Review[]
  
  @@index([email])
  @@index([role])
  @@index([organizationId])
}

enum Role {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?
  settings  Json?
  
  users     User[]
  courses   Course[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([slug])
  @@index([domain])
}

model Course {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  description     String
  thumbnail       String?
  videoIntro      String?
  price           Float    @default(0)
  instructorId    String
  organizationId  String?
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  instructor      User     @relation("InstructorCourses", fields: [instructorId], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])
  sections        Section[]
  enrollments     Enrollment[]
  reviews         Review[]
  orders          Order[]
  discussions     Discussion[]
  certificates    Certificate[]
  
  @@index([instructorId])
  @@index([organizationId])
  @@index([published])
}

model Section {
  id        String   @id @default(uuid())
  title     String
  courseId  String
  order     Int      @default(0)
  
  course    Course   @relation(fields: [courseId], references: [id])
  modules   Module[]
  
  @@index([courseId])
}

enum ModuleType {
  LESSON
  QUIZ
  ASSIGNMENT
  DISCUSSION
  SCORM
}

enum ContentStatus {
  PENDING
  GENERATING
  GENERATED
  APPROVED
  REJECTED
}

enum VideoStatus {
  PENDING
  GENERATING
  APPROVED
  REJECTED
  FAILED
}

model Module {
  id          String   @id @default(uuid())
  title       String
  sectionId   String
  type        ModuleType
  videoUrl    String?
  textContent String?
  content     Json?
  order       Int      @default(0)
  duration    Int?
  isPreview   Boolean  @default(false)
  hasVideo    Boolean  @default(false)
  videoGenId String?
  
  // Video Generation Fields
  topic              String?
  generatedContent   Json?
  contentStatus      ContentStatus @default(PENDING)
  videoStatus        VideoStatus   @default(PENDING)
  audioUrl           String?
  transcript         String?
  voiceId            String?
  
  // Approval workflow
  approvedAt          DateTime?
  approvedBy          String?
  rejectionReason     String?
  
  // Content generation tracking
  contentGeneratedAt DateTime?
  videoGeneratedAt   DateTime?
  retryCount         Int @default(0)
  
  section     Section  @relation(fields: [sectionId], references: [id])
  quiz        Quiz?
  assignment  Assignment?
  progresses  Progress[]
  
  @@index([sectionId])
}

model Quiz {
  id           String   @id @default(uuid())
  moduleId     String   @unique
  title        String
  description  String?
  timeLimit    Int?
  maxAttempts  Int      @default(1)
  passingScore Int      @default(50)
  shuffleQuestions Boolean @default(false)
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  module       Module   @relation(fields: [moduleId], references: [id])
  questions    Question[]
  attempts     QuizAttempt[]
}

model Question {
  id          String   @id @default(uuid())
  quizId      String
  type        String
  text        String
  options     Json?
  correctAnswer String?
  points      Int      @default(1)
  order       Int      @default(0)
  
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  @@index([quizId])
}

model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  quizId      String
  answers     Json
  score       Int?
  percentage  Float?
  passed      Boolean?
  startedAt   DateTime @default(now())
  completedAt DateTime?
  
  user        User     @relation(fields: [userId], references: [id])
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  @@index([userId])
  @@index([quizId])
}

model Assignment {
  id           String   @id @default(uuid())
  moduleId     String   @unique
  title        String
  description  String?
  dueDate      DateTime?
  maxPoints    Int      @default(100)
  allowFileUpload Boolean @default(true)
  allowedFileTypes String?
  
  module       Module   @relation(fields: [moduleId], references: [id])
  submissions  Submission[]
}

model Submission {
  id          String   @id @default(uuid())
  userId      String
  assignmentId String
  fileUrl     String?
  textContent String?
  grade       Int?
  feedback    String?
  submittedAt DateTime @default(now())
  gradedAt    DateTime?
  
  user        User     @relation(fields: [userId], references: [id])
  assignment  Assignment @relation(fields: [assignmentId], references: [id])
  @@index([userId])
  @@index([assignmentId])
}

model Enrollment {
  id           String   @id @default(uuid())
  userId       String
  courseId     String
  accessStatus String   @default("active")
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id])
  course       Course   @relation(fields: [courseId], references: [id])
  @@index([userId])
  @@index([courseId])
}

model Order {
  id                   String   @id @default(uuid())
  userId               String
  courseId             String
  amount               Float
  currency             String   @default("INR")
  status               String   @default("PENDING")
  razorpayOrderId      String?
  razorpayPaymentId    String?
  paymentMethod        String?
  createdAt            DateTime @default(now())
  
  user                 User     @relation(fields: [userId], references: [id])
  course               Course   @relation(fields: [courseId], references: [id])
  @@index([userId])
  @@index([status])
}

model SubscriptionPlan {
  id                String   @id @default(uuid())
  name              String
  description       String?
  price             Float
  billingCycle      String   @default("monthly") // monthly, yearly, quarterly
  features          Json?    // JSON array of features included in the plan
  maxCourses        Int      @default(-1) // -1 means unlimited
  maxStudents       Int      @default(-1) // -1 means unlimited
  supportLevel      String   @default("basic") // basic, premium, enterprise
  isActive          Boolean  @default(true)
  razorpayPlanId    String?  // Razorpay Plan ID for recurring payments
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  subscriptions     Subscription[]
  
  @@index([isActive])
  @@index([billingCycle])
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  planId               String
  status               String   @default("active") // active, cancelled, expired, paused
  currentPeriodStart   DateTime @default(now())
  currentPeriodEnd     DateTime
  nextBillingDate      DateTime?
  cancelledAt          DateTime?
  razorpaySubscriptionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  user                 User     @relation(fields: [userId], references: [id])
  plan                 SubscriptionPlan @relation(fields: [planId], references: [id])
  @@index([userId])
  @@index([status])
  @@index([planId])
}

model Progress {
  id           String   @id @default(uuid())
  userId       String
  moduleId     String
  completed    Boolean  @default(false)
  timeSpent    Int      @default(0)
  courseProgress Float?  @default(0)
  lastAccessed DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id])
  module       Module   @relation(fields: [moduleId], references: [id])
  @@index([userId])
  @@index([moduleId])
}

model AIGenerationJob {
  id          String   @id @default(uuid())
  type        String
  status      String   @default("pending")
  input       Json
  output      Json?
  error       String?
  retryCount  Int      @default(0)
  version     String
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([tenantId])
}

model VideoGeneration {
  id           String   @id @default(uuid())
  moduleId     String   @unique
  script       String   @default("")
  audioUrl     String?
  videoUrl     String?
  status       String   @default("PENDING")
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([status])
  @@index([moduleId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  rating    Int      @default(5)
  comment   String?
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  @@index([courseId])
}

model Discussion {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  title     String
  content   String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  replies   Reply[]
  @@index([courseId])
}

model Reply {
  id           String   @id @default(uuid())
  userId       String
  discussionId String
  content      String
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id])
  discussion   Discussion @relation(fields: [discussionId], references: [id])
  @@index([discussionId])
}

model Certificate {
  id          String   @id @default(uuid())
  userId      String
  courseId    String
  issuedAt    DateTime @default(now())
  pdfUrl      String?
  
  user        User     @relation(fields: [userId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])
  @@index([userId])
  @@index([courseId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([read])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String
  courseId  String?
  moduleId  String?
  type      String
  metadata  Json
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([courseId])
  @@index([createdAt])
}

model Plugin {
  id          String   @id @default(uuid())
  pluginId    String   @unique
  name        String
  description String?
  version     String
  author      String?
  category    PluginCategory @default(CONTENT)
  icon        String?
  enabled     Boolean  @default(false)
  config      Json?
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PluginCategory {
  CONTENT
  GAMIFICATION
  ANALYTICS
  USERMGMT
  COMMUNICATION
  PAYMENTS
  INTEGRATIONS
  AI
  UTILITY
}
